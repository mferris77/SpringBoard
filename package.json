{
  "name": "springboard-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "SpringBoard Local-First AI Assistant - Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/springboard-desktop",
    "dev:backend": "npm run dev --workspace=apps/springboard-backend",
    "dev:python": "cd services/springboard-python && python src/main.py",
    "dev:all": "concurrently --kill-others --handle-input -n desktop,backend,python -c cyan,magenta,green \"npm run dev --workspace=apps/springboard-desktop\" \"npm run dev --workspace=apps/springboard-backend\" \"npm run dev:python\"",
    "build": "npm run build --workspaces",
    "build:desktop": "npm run build --workspace=apps/springboard-desktop",
    "build:backend": "npm run build --workspace=apps/springboard-backend",
    "build:contracts": "npm run build --workspace=packages/springboard-contracts",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "clean": "rm -rf apps/*/dist apps/*/node_modules packages/*/dist packages/*/node_modules node_modules",
    "docs:build": "node ./scripts/build-docs.mjs",
    "lint:python": "python -m ruff check python",
    "format:python": "python -m ruff format python"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@primevue/themes": "^4.5.4",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "concurrently": "^9.2.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "leaflet": "^1.9.4",
    "marked": "^17.0.4",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/dagre": "^0.7.54",
    "@types/dompurify": "^3.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "turbo": "^1.12.5",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
